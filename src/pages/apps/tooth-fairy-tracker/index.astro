---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Tooth Fairy Tracker"
  description="Track every lost tooth, every Tooth Fairy visit, and every payout. No subscriptions — just a simple, joyful app for families."
>
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-content">
      <span class="section-label">// tooth fairy tracker</span>
      <h1>Every Lost Tooth,<br />Worth Remembering</h1>
      <p class="hero-sub">
        Track every lost tooth, every Tooth Fairy visit, and every payout.
        A simple, joyful app built for one of childhood's most universal traditions.
      </p>
      <div class="hero-actions">
        <a href="#" class="btn btn-primary btn-lg">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
          Download on the App Store
        </a>
        <a href="/apps/tooth-fairy-tracker/privacy" class="btn btn-outline">Privacy Policy</a>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-label">// features</span>
        <h2>Capture the magic of every milestone</h2>
      </div>

      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">&#129463;</div>
          <h3>Visual Mouth Diagram</h3>
          <p>
            An interactive diagram shows exactly which teeth have come out
            and which ones are still hanging on. Tap any tooth to log it.
          </p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">&#128197;</div>
          <h3>Visit History</h3>
          <p>
            A complete timeline of every Tooth Fairy visit — dates, amounts,
            and notes. Kids will love reading these back years from now.
          </p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">&#128176;</div>
          <h3>Customizable Payouts</h3>
          <p>
            Record whatever amount works for your family. See running totals
            over time for each child.
          </p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">&#128106;</div>
          <h3>Multiple Children</h3>
          <p>
            Each child gets their own diagram, history, and totals —
            completely separate. Unlock unlimited profiles with one purchase.
          </p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">&#128274;</div>
          <h3>Private by Design</h3>
          <p>
            No account, no internet required. All data stored locally
            on your device. No analytics, no tracking, no ads.
          </p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">&#128588;</div>
          <h3>Kid-Friendly Design</h3>
          <p>
            Large tap targets, clean interface, and Dynamic Type support.
            Built for the whole family to enjoy together.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header" style="text-align: center;">
        <span class="section-label">// pricing</span>
        <h2>Simple Pricing</h2>
        <p class="pricing-sub">Free for your first child. Upgrade once for the whole family.</p>
      </div>

      <div class="pricing-grid">
        <div class="pricing-card">
          <h3>Free</h3>
          <p class="price">$0</p>
          <ul>
            <li>One child profile</li>
            <li>Full mouth diagram</li>
            <li>Visit history &amp; notes</li>
            <li>Payout tracking</li>
          </ul>
        </div>
        <div class="pricing-card pricing-card-premium">
          <h3>Unlimited Children</h3>
          <p class="price">$2.99 <span class="price-note">one-time</span></p>
          <ul>
            <li>Unlimited child profiles</li>
            <li>Separate history per child</li>
            <li>Running totals per child</li>
            <li>No subscription — ever</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="section">
    <div class="container bottom-cta">
      <p>Available on iPhone and iPad. Requires iOS 17 or later.</p>
      <a href="#" class="btn btn-primary btn-lg">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
        </svg>
        Download on the App Store
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    padding: 6rem 0 5rem;
    border-bottom: 1px solid var(--border);
  }

  .hero-content {
    max-width: 680px;
  }

  .hero h1 {
    margin-bottom: 1.25rem;
  }

  .hero-sub {
    font-size: 1.1rem;
    max-width: 52ch;
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-lg {
    padding: 0.75rem 1.75rem;
    font-size: 1rem;
  }

  /* Features */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .feature-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }

  .feature-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .feature-icon {
    font-size: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .feature-card h3 {
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }

  .feature-card p {
    font-size: 0.875rem;
    line-height: 1.6;
  }

  /* Section alt */
  .section-alt {
    background: var(--surface);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  /* Pricing */
  .pricing-sub {
    margin-top: 0.5rem;
    font-size: 1rem;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    max-width: 560px;
    margin: 0 auto;
  }

  .pricing-card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    text-align: left;
  }

  .pricing-card-premium {
    border-color: var(--accent);
    background: var(--accent-dim);
  }

  .pricing-card h3 {
    font-size: 1.05rem;
    margin-bottom: 0.5rem;
  }

  .price {
    font-size: 2rem;
    font-weight: 800;
    color: var(--text);
    margin-bottom: 1.25rem;
  }

  .price-note {
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--text-muted);
  }

  .pricing-card ul {
    list-style: none;
    padding: 0;
  }

  .pricing-card li {
    font-size: 0.875rem;
    color: var(--text-muted);
    padding: 0.35rem 0;
    padding-left: 1.25rem;
    position: relative;
  }

  .pricing-card li::before {
    content: '\2713';
    position: absolute;
    left: 0;
    color: var(--success);
    font-weight: 600;
  }

  /* Bottom CTA */
  .bottom-cta {
    text-align: center;
  }

  .bottom-cta p {
    font-size: 0.875rem;
    margin-bottom: 1rem;
  }

  /* Mobile */
  @media (max-width: 600px) {
    .hero { padding: 3rem 0 3rem; }
    .features-grid { grid-template-columns: 1fr; }
    .pricing-grid { grid-template-columns: 1fr; }
  }
</style>
